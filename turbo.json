{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "cmd/mypal/public/**"]
    },
    "@mypal/frontend#build": {
      "dependsOn": ["^build"],
      "outputs": ["../../apps/backend/cmd/mypal/public/assets/**"]
    },
    "@mypal/backend#build": {
      "dependsOn": ["^build", "@mypal/frontend#build"],
      "outputs": ["../../dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    }
  },
  "globalPassThroughEnv": ["MYPAL_GRAPHQL_AUTH_TOKEN", "MYPAL_CONFIG"],
  "ui": "tui"
}
